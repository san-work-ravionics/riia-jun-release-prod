{
  "manifest_version": 3,
  "name": "RIIA UI Automation",
  "version": "1.0",
  "description": "Desktop UI layout automation tests for RIIA.",
  "permissions": [
    "activeTab",
    "scripting",
    "debugger",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Run UI Tests"
  }
}
